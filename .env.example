# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit keys.
#
# Every name here maps to a field on Settings in app/config.py.
# pydantic-settings matches them case-insensitively.

# Which client implementation to use: "stub" or "azure".
# This one line is the provider seam. Nothing else in the codebase knows.
LLM_PROVIDER=stub

# Which embedding provider retrieval uses: "local" or "azure".
# "local" = bge-small-en-v1.5 on CPU (free, no key, ~130MB download on first use).
# "azure" = the embedding deployment below. Mixing local embeddings with azure
# chat is a legitimate production configuration — hence a separate knob.
EMBEDDING_PROVIDER=local

# ---- Ops (phase 9) -----------------------------------------------------------
# "No record, no answer": while the audit sink is failing writes, /v1/ask
# returns 503 + Retry-After instead of serving un-audited exchanges, and
# /ready reports the pod as not-ready. Disable only where availability
# explicitly outranks the audit record.
AUDIT_STRICT=true

# ---- Safety (phase 8) --------------------------------------------------------
# Redact PII (emails, phones, vehicle regs) from audit records and handoff
# notes before storage. ON by default — disable only with a documented
# retention requirement.
AUDIT_REDACT_PII=true

# ---- Vector store (phase 5) --------------------------------------------------
# "memory" (default): embeds the fixture corpus at boot; nothing persists.
# "qdrant": persistent. Run `python -m app.ingest.index` ONCE first — the app
# fails closed at boot if the store is empty.
VECTOR_STORE=memory
# Embedded mode: a local folder, no server, single process.
QDRANT_PATH=var/qdrant
# Set a URL to use a Qdrant SERVER instead of the folder (docker or cloud).
# The same client, the same code — deployment is config.
QDRANT_URL=
QDRANT_COLLECTION=chunks

# ---- Azure OpenAI (only needed when LLM_PROVIDER=azure) ----------------------
# See AZURE_SETUP.md for how to obtain these.
#
# The endpoint is the RESOURCE url, not the deployment url.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=
#
# The api_version is a DATE. It pins the shape of the REST contract.
# Structured outputs (json_schema) need 2024-08-01-preview or later.
AZURE_OPENAI_API_VERSION=2024-10-21
#
# NOTE: this is your *deployment name* — the label YOU chose in Azure —
# not the model name. A deployment called "prod-chat" may point at gpt-4o.
# Getting this wrong is the #1 first-time Azure OpenAI error.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ---- Resilience knobs (section 1.4) ------------------------------------------
# Total seconds allowed for one LLM call, end to end.
LLM_TIMEOUT_SECONDS=60
# Seconds allowed just to establish the TCP+TLS connection.
LLM_CONNECT_TIMEOUT_SECONDS=2
# Max in-flight calls to the provider from THIS process. The semaphore cap.
LLM_MAX_CONCURRENCY=8
# How many times we retry a retryable failure (429/5xx). Attempts = retries + 1.
LLM_MAX_RETRIES=2
# How long a request queues for a semaphore slot before we shed it with our
# own 429 + Retry-After. Rejecting in 5ms is kinder than timing out in 60s.
LLM_ACQUIRE_TIMEOUT_SECONDS=0.5
# Circuit breaker: consecutive provider-health failures before we stop calling,
# and how long we stay open before allowing one probe through.
LLM_BREAKER_THRESHOLD=5
LLM_BREAKER_COOLDOWN_SECONDS=30

# ---- Auth (phase 2) -----------------------------------------------------------
# HS256 signing secret for bearer tokens. REQUIRED — there is no default, and
# the API refuses to boot without one (fail closed, at boot, on purpose).
# Generate a real one:
#   python -c "import secrets; print(f'AUTH_JWT_SECRET={secrets.token_hex(32)}')" >> .env
# Then mint tokens with:  python -m app.auth --tenant asha --groups customer
# Production replaces this scheme with the IdP's RS256/JWKS keys (app/auth.py).
AUTH_JWT_SECRET=
