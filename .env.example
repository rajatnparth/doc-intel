# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit keys.
#
# Every name here maps to a field on Settings in app/config.py.
# pydantic-settings matches them case-insensitively.

# Which client implementation to use: "stub" or "azure".
# This one line is the provider seam. Nothing else in the codebase knows.
LLM_PROVIDER=stub

# Which embedding provider retrieval uses: "local" or "azure".
# "local" = bge-small-en-v1.5 on CPU (free, no key, ~130MB download on first use).
# "azure" = the embedding deployment below. Mixing local embeddings with azure
# chat is a legitimate production configuration — hence a separate knob.
EMBEDDING_PROVIDER=local

# ---- Azure OpenAI (only needed when LLM_PROVIDER=azure) ----------------------
# See AZURE_SETUP.md for how to obtain these.
#
# The endpoint is the RESOURCE url, not the deployment url.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=
#
# The api_version is a DATE. It pins the shape of the REST contract.
# Structured outputs (json_schema) need 2024-08-01-preview or later.
AZURE_OPENAI_API_VERSION=2024-10-21
#
# NOTE: this is your *deployment name* — the label YOU chose in Azure —
# not the model name. A deployment called "prod-chat" may point at gpt-4o.
# Getting this wrong is the #1 first-time Azure OpenAI error.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ---- Resilience knobs (section 1.4) ------------------------------------------
# Total seconds allowed for one LLM call, end to end.
LLM_TIMEOUT_SECONDS=60
# Seconds allowed just to establish the TCP+TLS connection.
LLM_CONNECT_TIMEOUT_SECONDS=2
# Max in-flight calls to the provider from THIS process. The semaphore cap.
LLM_MAX_CONCURRENCY=8
# How many times we retry a retryable failure (429/5xx). Attempts = retries + 1.
LLM_MAX_RETRIES=2
